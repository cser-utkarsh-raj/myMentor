# myMentor Backend Configuration

# App settings
PORT=8000
UPLOAD_FOLDER=./uploads

# Database settings
# For SQLite: sqlite:///./mymentor.db
# For PostgreSQL: postgresql://username:password@localhost:5432/mymentor
DATABASE_URL=sqlite:///./mymentor.db

# Security
JWT_SECRET=supersecretjwtkeyforlocaldevelopmentonlychangeinprod

# AI Services (V2 Expansion)
OPENAI_API_KEY=your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
